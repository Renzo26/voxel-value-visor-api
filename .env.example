# Banco de dados — usar o Session Pooler do Supabase (porta 5432, IPv4)
# Formato: postgresql+asyncpg://USUARIO:SENHA@HOST:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:senha@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=troque-por-uma-chave-secreta-de-pelo-menos-256-bits

# App
APP_ENV=development
APP_PORT=8000

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Uploads — URL pública do backend (usada para montar o link das fotos)
PUBLIC_BASE_URL=http://localhost:8000
